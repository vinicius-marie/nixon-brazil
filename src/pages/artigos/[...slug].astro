---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('artigos', ({ data }) => !data.draft);
  return articles.map((article) => ({ params: { slug: article.id }, props: { article } }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const base = import.meta.env.BASE_URL;
const rawCover = article.data.cover ?? '';
const cover = rawCover
  ? (rawCover.startsWith('http') ? rawCover : `${base}${rawCover.replace(/^\//, '')}`)
  : undefined;
const words = article.body?.split(/\s+/).filter(Boolean).length ?? 0;
const minutes = Math.max(1, Math.round(words / 220));
---
<BaseLayout title={article.data.title} description={article.data.description} image={cover} type="article">
  <article>
    <header class="article-header">
      <p class="kicker">{article.data.category}</p>
      <h1>{article.data.title}</h1>
      {article.data.subtitle && <p class="article-deck">{article.data.subtitle}</p>}
      <div class="article-meta-row">
        <span>{article.data.author}</span>
        <span>{article.data.publishedAt.toLocaleDateString('pt-BR')}</span>
        <span>{minutes} min de leitura</span>
      </div>
    </header>
    {cover && (
      <figure class="article-cover">
        <img src={cover} alt={article.data.coverAlt ?? ''} width="1240" height="700" loading="eager" decoding="async" />
        {article.data.coverCredit && <figcaption>{article.data.coverCredit}</figcaption>}
      </figure>
    )}
    <div class="article-body">
      <Content />
      {article.data.sourceUrl && (
        <aside class="article-sources">
          <h2>Fonte de partida</h2>
          <ul>
            <li><a href={article.data.sourceUrl} target="_blank" rel="noreferrer">Documento ou coleção principal ↗</a></li>
          </ul>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>
