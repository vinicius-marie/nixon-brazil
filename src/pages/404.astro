---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="Página não encontrada" description="A página solicitada não existe no Nixon Brasil.">
  <section class="page-hero light"><div class="shell"><p class="kicker">Erro 404</p><h1>Página não encontrada.</h1><p>O endereço pode ter mudado ou ainda não foi publicado.</p><div class="actions"><a class="btn dark" href={base}>Voltar ao início</a></div></div></section>
</BaseLayout>
