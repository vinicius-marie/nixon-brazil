---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const articles = (await getCollection('artigos', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const featured = articles.filter(({ data }) => data.featured).slice(0, 3);
---
<BaseLayout
  title="Nixon Brasil"
  description="Portal editorial brasileiro sobre a vida, a Presidência, a política externa e o legado de Richard Nixon."
>
  <section class="hero">
    <img class="hero-media" src="https://commons.wikimedia.org/wiki/Special:Redirect/file/NIXONcampaigns.jpg" alt="Richard Nixon em campanha diante de uma multidão em 1968" width="1600" height="900" fetchpriority="high" decoding="async" />
    <div class="shell hero-content">
      <div class="hero-copy">
        <p class="kicker light">1913 — 1994</p>
        <h1>Um outsider no centro da história.</h1>
        <p>Da juventude na Califórnia à Casa Branca; das derrotas eleitorais à abertura da China. A trajetória, as decisões e o legado de Richard Nixon reunidos em português.</p>
        <div class="actions">
          <a class="btn primary" href={`${base}biografia/`}>Conheça a trajetória</a>
          <a class="btn ghost" href={`${base}presidencia/`}>Explore a Presidência</a>
        </div>
      </div>
    </div>
    <p class="photo-credit">Ollie Atkins / NARA · NAID 194286 · domínio público</p>
  </section>

  <section class="impact-strip" aria-label="Dados centrais">
    <div class="shell impact-grid">
      <div><strong>37º</strong><span>Presidente dos Estados Unidos</span></div>
      <div><strong>49</strong><span>Estados vencidos em 1972</span></div>
      <div><strong>1972</strong><span>Abertura histórica à China</span></div>
      <div><strong>10</strong><span>Livros publicados</span></div>
    </div>
  </section>

  <section class="section white">
    <div class="shell">
      <div class="section-head">
        <div><p class="kicker">Destaques</p><h2>Os momentos que definiram uma Presidência.</h2></div>
        <p>Campanha, poder interno, diplomacia e instituições apresentados por narrativas editoriais, documentos e imagens de arquivo.</p>
      </div>
      <div class="story-grid">
        <a class="story" href={`${base}politica-externa/`}>
          <img src="https://commons.wikimedia.org/wiki/Special:Redirect/file/President_Richard_Nixon_and_Mao_Zedong.jpg" alt="Richard Nixon cumprimenta Mao Zedong em Pequim" width="1200" height="900" loading="lazy" decoding="async" />
          <div class="story-copy"><span class="story-meta">China · 1972</span><h3>A semana que alterou o equilíbrio mundial</h3><p>Estratégia triangular, diplomacia secreta e o Comunicado de Xangai.</p></div>
        </a>
        <a class="story small" href={`${base}presidencia/`}>
          <img src="https://commons.wikimedia.org/wiki/Special:Redirect/file/President_Richard_Nixon_Signing_the_National_Environmental_Policy_Act_of_1969_(cropped).jpg" alt="Nixon assina a National Environmental Policy Act" width="800" height="600" loading="lazy" decoding="async" />
          <div class="story-copy"><span class="story-meta">Política interna</span><h3>O Estado ambiental moderno</h3></div>
        </a>
        <a class="story small" href={`${base}biografia/`}>
          <img src="https://commons.wikimedia.org/wiki/Special:Redirect/file/RichardNixon.jpg" alt="Retrato oficial de Richard Nixon" width="800" height="1000" loading="lazy" decoding="async" />
          <div class="story-copy"><span class="story-meta">Vida e carreira</span><h3>Da derrota ao retorno</h3></div>
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-head">
        <div><p class="kicker">A Presidência</p><h2>Resultados que permanecem.</h2></div>
        <p>Leis, órgãos e acordos que continuam presentes na estrutura institucional dos Estados Unidos.</p>
      </div>
      <div class="policy-grid">
        <article class="policy"><b>01 · MEIO AMBIENTE</b><h3>EPA e ar limpo</h3><p>Criação da Environmental Protection Agency e consolidação da regulação federal ambiental.</p></article>
        <article class="policy"><b>02 · TRABALHO</b><h3>OSHA</h3><p>Estrutura nacional para saúde e segurança ocupacional.</p></article>
        <article class="policy"><b>03 · SAÚDE</b><h3>National Cancer Act</h3><p>Expansão federal da pesquisa, do financiamento e da coordenação contra o câncer.</p></article>
        <article class="policy"><b>04 · EDUCAÇÃO</b><h3>Title IX</h3><p>Proibição da discriminação sexual em programas educacionais financiados pelo governo federal.</p></article>
        <article class="policy"><b>05 · SEGURANÇA</b><h3>Forças voluntárias</h3><p>Encerramento do recrutamento militar em tempo de paz e transição para uma força profissional.</p></article>
        <article class="policy"><b>06 · DIPLOMACIA</b><h3>Détente</h3><p>SALT I e Tratado ABM como instrumentos de contenção negociada da competição nuclear.</p></article>
      </div>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="section white">
      <div class="shell">
        <div class="section-head"><div><p class="kicker">Publicação</p><h2>Artigos em destaque.</h2></div><a class="btn dark" href={`${base}artigos/`}>Ver todos</a></div>
        <div class="cards">
          {featured.map((article) => {
            const raw = article.data.cover ?? '';
            const cover = raw.startsWith('http') ? raw : raw ? `${base}${raw.replace(/^\//, '')}` : '';
            return (
            <a class="card" href={`${base}artigos/${article.id}/`}>
              {cover
                ? <img src={cover} alt={article.data.coverAlt ?? ''} width="640" height="360" loading="lazy" decoding="async" />
                : <div class="card-cover-fallback" aria-hidden="true">{article.data.category}</div>}
              <div class="card-body"><span class="card-meta">{article.data.category} · {article.data.publishedAt.toLocaleDateString('pt-BR')}</span><h3>{article.data.title}</h3><p>{article.data.description}</p></div>
            </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <section class="section navy">
    <div class="shell section-head">
      <div><p class="kicker light">Nixon e o Brasil</p><h2>Uma relação de interesse nacional.</h2></div>
      <div><p>Comércio, café, pesca, energia, investimento e estratégia hemisférica. O portal trata o Brasil como ator político, sem converter a ditadura ou seus dirigentes em objeto de celebração.</p><div class="actions"><a class="btn primary" href={`${base}brasil/`}>Abrir o dossiê Brasil</a></div></div>
    </div>
  </section>
</BaseLayout>
