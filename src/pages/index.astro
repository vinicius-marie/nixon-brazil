---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const articles = (await getCollection('artigos', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const lead = articles[0];
const rest = articles.slice(1, 5);
const docs = await getCollection('documentos');

function coverOf(article: (typeof articles)[number]) {
  const raw = article.data.cover ?? '';
  if (!raw) return '';
  return raw.startsWith('http') ? raw : `${base}${raw.replace(/^\//, '')}`;
}
---
<BaseLayout
  title="Nixon Brasil"
  description="Defesa documentada do legado de Richard Nixon em português: China, Presidência, Brasil e arquivo."
>
  <section class="hero hero-v2">
    <img
      class="hero-media"
      src="https://commons.wikimedia.org/wiki/Special:Redirect/file/NIXONcampaigns.jpg"
      alt="Richard Nixon em campanha diante de uma multidão em 1968"
      width="1600"
      height="900"
      fetchpriority="high"
      decoding="async"
    />
    <div class="shell hero-content">
      <div class="hero-copy">
        <p class="hero-badge">Arquivo · ensaio · apologia</p>
        <p class="kicker light">1913 — 1994 · 37º Presidente dos EUA</p>
        <h1>Nixon em português.<br /><em>Sem desculpas.</em></h1>
        <p class="hero-lead">
          Portal editorial que defende o legado com documento na mesa:
          abertura da China, Estado ambiental, détente e o Brasil como potência regional.
        </p>
        <div class="actions">
          <a class="btn primary" href={`${base}artigos/`}>Ler os artigos</a>
          <a class="btn gold" href={`${base}acervo/`}>Abrir o acervo</a>
          <a class="btn ghost" href={`${base}politica-externa/`}>China · 1972</a>
        </div>
      </div>
    </div>
    <p class="photo-credit">Ollie Atkins / NARA · domínio público</p>
  </section>

  <section class="ticker" aria-label="Linha editorial">
    <div class="shell ticker-inner">
      <strong>Posição</strong>
      <span>Favorável ao legado · fontes da Casa Branca, FRUS e NARA · independente</span>
      <a href={`${base}sobre/`}>Sobre o projeto →</a>
    </div>
  </section>

  <section class="impact-strip impact-v2" aria-label="Números">
    <div class="shell impact-grid">
      <div><strong>49</strong><span>Estados em 1972</span></div>
      <div><strong>1972</strong><span>Abertura à China</span></div>
      <div><strong>{articles.length}</strong><span>Artigos no ar</span></div>
      <div><strong>{docs.length}</strong><span>Peças no acervo</span></div>
    </div>
  </section>

  {lead && (
    <section class="section white lead-section">
      <div class="shell">
        <div class="section-head tight">
          <div>
            <p class="kicker">Capa da semana</p>
            <h2>O que ler agora.</h2>
          </div>
          <a class="btn dark" href={`${base}artigos/`}>Todos os artigos</a>
        </div>

        <a class="lead-card" href={`${base}artigos/${lead.id}/`}>
          {coverOf(lead)
            ? <img src={coverOf(lead)} alt={lead.data.coverAlt ?? ''} width="1200" height="675" loading="eager" decoding="async" />
            : <div class="card-cover-fallback lead-fallback" aria-hidden="true">{lead.data.category}</div>}
          <div class="lead-copy">
            <span class="card-meta">{lead.data.category} · {lead.data.publishedAt.toLocaleDateString('pt-BR')}</span>
            <h3>{lead.data.title}</h3>
            <p>{lead.data.subtitle ?? lead.data.description}</p>
            <span class="read-link">Ler o ensaio completo →</span>
          </div>
        </a>

        {rest.length > 0 && (
          <div class="home-article-grid">
            {rest.map((article) => {
              const cover = coverOf(article);
              return (
                <a class="home-article" href={`${base}artigos/${article.id}/`}>
                  {cover
                    ? <img src={cover} alt={article.data.coverAlt ?? ''} width="640" height="360" loading="lazy" decoding="async" />
                    : <div class="card-cover-fallback" aria-hidden="true">{article.data.category}</div>}
                  <div>
                    <span class="card-meta">{article.data.category}</span>
                    <h3>{article.data.title}</h3>
                    <p>{article.data.description}</p>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </section>
  )}

  <section class="section quote-band">
    <div class="shell quote-inner">
      <p class="kicker light">Linha editorial</p>
      <blockquote>
        A charge de Watergate não apaga a China, a EPA, o SALT nem o mapa hemisférico.
        Este site existe para devolver escala ao arquivo — em português.
      </blockquote>
      <a class="btn primary" href={`${base}artigos/abertura-china/`}>Começar pela China →</a>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="kicker">Mapa do site</p>
          <h2>Quatro entradas.</h2>
        </div>
        <p>Escolha o eixo. Cada página liga narrativa a documento.</p>
      </div>
      <div class="entry-grid">
        <a class="entry" href={`${base}politica-externa/`}>
          <span>01</span>
          <h3>Política externa</h3>
          <p>China, détente, triângulo estratégico.</p>
        </a>
        <a class="entry" href={`${base}presidencia/`}>
          <span>02</span>
          <h3>Presidência</h3>
          <p>EPA, leis, capacidade de Estado.</p>
        </a>
        <a class="entry" href={`${base}brasil/`}>
          <span>03</span>
          <h3>Nixon e o Brasil</h3>
          <p>Potência regional, barganha, FRUS.</p>
        </a>
        <a class="entry" href={`${base}biografia/`}>
          <span>04</span>
          <h3>Biografia</h3>
          <p>Do outsider de Whittier ao retorno de 1968.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="section navy cta-brasil">
    <div class="shell cta-brasil-inner">
      <div>
        <p class="kicker light">Hemisfério</p>
        <h2>Washington tratou o Brasil como ator — não como figurante.</h2>
      </div>
      <div>
        <p>Café, status regional, energia e fricção diplomática no arquivo dos anos Nixon.</p>
        <div class="actions">
          <a class="btn primary" href={`${base}brasil/`}>Dossiê Brasil</a>
          <a class="btn ghost" href={`${base}artigos/brasil-potencia-regional/`}>Ler o ensaio</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
